// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

 model User {
    id                String      @id @default(cuid())
    clerkId           String      @unique
    email             String      @unique
    firstName         String?
    lastName          String?
    role              UserRole    @default(CUSTOMER)
    phone             String?
    isAdmin           Boolean     @default(false)
    profileImage      String?
    createdAt         DateTime    @default(now())
    updatedAt         DateTime    @updatedAt
    latitude          Float?
    longitude         Float?
    lastLocationUpdate DateTime?

    // Notification preferences
    emailNotifications Boolean    @default(true)
    smsNotifications   Boolean    @default(false)
    pushNotifications  Boolean    @default(true)

    // Onboarding status
    onboardingStep     Int         @default(1) // For driver onboarding flow
    onboardingCompleted Boolean   @default(false)
    applicationStatus  ApplicationStatus @default(PENDING)

    addresses         Address[]
    deliveries        Delivery[]  @relation("CustomerDeliveries")
    driverDeliveries  Delivery[]  @relation("DriverDeliveries")
    orders            Order[]
    reviews           Review[]
    pushSubscriptions PushSubscription[]
    payments          Payment[]
    driverPayouts     DriverPayout[]
    driverDocuments   DriverDocument[]

    // Driver profile fields
    licenseNumber     String?     @unique
    licenseExpiry     DateTime?
    vehicleType       String?
    vehicleMake       String?
    vehicleModel      String?
    vehicleYear       Int?
    vehiclePlate      String?     @unique
    vehicleColor      String?
    isDriverVerified  Boolean     @default(false)
    isDriverActive    Boolean     @default(false)
    driverRating      Float       @default(0)
    totalDeliveries   Int         @default(0)
    bio               String?
    yearsOfExperience Int?
    languages         String?     // JSON array of languages
  }

model Address {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  street            String
  city              String
  state             String
  zipCode           String
  country           String
  latitude          Float?
  longitude         Float?
  label             String?
  isDefault         Boolean     @default(false)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  pickupDeliveries  Delivery[]  @relation("PickupAddress")
  dropoffDeliveries Delivery[]  @relation("DropoffAddress")
  
  @@index([userId])
}

 model Delivery {
   id                String      @id @default(cuid())
   customerId        String
   customer          User        @relation("CustomerDeliveries", fields: [customerId], references: [id], onDelete: Cascade)
   
   driverId          String?
   driver            User?       @relation("DriverDeliveries", fields: [driverId], references: [id], onDelete: SetNull)
   
   pickupAddressId   String
   pickupAddress     Address     @relation("PickupAddress", fields: [pickupAddressId], references: [id])
   
   dropoffAddressId  String
   dropoffAddress    Address     @relation("DropoffAddress", fields: [dropoffAddressId], references: [id])
   
   orderId           String?     @unique
   order             Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
   
   status            DeliveryStatus @default(PENDING)
   priority          Priority    @default(NORMAL)
   distance          Float?
   estimatedTime     Int?
   actualTime        Int?
   
    notes             String?
    description       String?
    weight            Float?
    dimensions        String?
    
    pickupTime        DateTime?
    deliveryTime      DateTime?
    scheduledTime     DateTime?
    assignedAt        DateTime?
    
    // Payment fields
    paymentStatus     PaymentStatus @default(PENDING)
    paymentIntentId   String?      @unique
    paymentMethod     String?
    paymentCurrency   String      @default("KES")
    paymentAmount     Float?
    
    cost              Float
    tip               Float       @default(0)
    
    createdAt         DateTime    @default(now())
    updatedAt         DateTime    @updatedAt
    
    review            Review?
    payment           Payment?
    driverPayout      DriverPayout?
    
    @@index([customerId])
    @@index([driverId])
    @@index([status])
    @@index([paymentStatus])
 }

model Order {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items             String      // JSON array of items
  totalAmount       Float
  status            OrderStatus @default(PENDING)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  delivery          Delivery?
  
  @@index([userId])
  @@index([status])
}

 model Review {
   id                String      @id @default(cuid())
   deliveryId        String      @unique
   delivery          Delivery    @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
   
   userId            String
   user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
   
   rating            Int         // 1-5
   comment           String?
   
   createdAt         DateTime    @default(now())
   updatedAt         DateTime    @updatedAt
   
   @@index([userId])
 }

model PushSubscription {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint         String   @unique
  keys             Json?    // { p256dh, auth }
  deviceType       String?  // browser, mobile, etc.
  isActive         Boolean  @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

model DriverDocument {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              DocumentType
  name              String      // Display name
  url               String      // Storage URL
  publicId          String?     // Cloud storage public ID
  mimeType          String
  size              Int

  isVerified        Boolean     @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?

  rejectionReason   String?
  uploadedAt        DateTime    @default(now())

  @@index([userId])
  @@index([type])
  @@index([isVerified])
}

enum DocumentType {
  ID_CARD
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  INSURANCE_CERTIFICATE
  PROFILE_PHOTO
  OTHER
}

enum UserRole {
  ADMIN
  DRIVER
  CUSTOMER
}

enum ApplicationStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ADDITIONAL_INFO_REQUIRED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  DELIVERY_PAYMENT    // Customer pays for delivery
  DRIVER_PAYOUT       // Driver receives payment
  TIP                 // Customer tip
  REFUND              // Refund to customer
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Payment {
  id                String      @id @default(cuid())
  deliveryId        String?     @unique
  delivery          Delivery?   @relation(fields: [deliveryId], references: [id])
  
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  
  type              PaymentType
  amount            Float
  currency          String      @default("KES")
  status            PaymentStatus @default(PENDING)
  
  provider          String?     // "pesapal", "stripe", etc.
  providerPaymentId String?     @unique
  
  metadata          Json?       // Additional data
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  @@index([userId])
  @@index([deliveryId])
  @@index([status])
}

model DriverPayout {
  id                String      @id @default(cuid())
  driverId          String
  driver            User        @relation(fields: [driverId], references: [id])

  deliveryId        String      @unique
  delivery          Delivery    @relation(fields: [deliveryId], references: [id])

  amount            Float
  currency          String      @default("KES")
  status            PayoutStatus @default(PENDING)

  provider          String?     // "pesapal", "paypal", etc.
  providerPayoutId  String?     @unique

  paidAt            DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([driverId])
  @@index([status])
}

model PricingRule {
  id                String      @id @default(cuid())
  name              String
  description       String?
  baseFare          Float
  costPerKm         Float
  minimumFare       Float
  priorityMultiplier Json      // { NORMAL: 1, URGENT: 1.5, HIGH: 1.3, LOW: 0.9 }
  vehicleType       String?     // null = all types, or specific vehicle type
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}
